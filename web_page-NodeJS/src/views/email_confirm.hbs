<link rel="stylesheet" href="/css/auth/confirm.css">

{{> main/header}}
<section class="confirm" id="confirm" role="region"
    aria-label="Confirmación de solicitud de restablecimiento de contraseña" itemscope
    itemtype="https://schema.org/WebApplication">
    <div class="container max-width">
        <h1 itemprop="name">Solicitud Exitosa</h1>
        <p class="intro" itemprop="description">
            Hemos enviado un correo electrónico con las instrucciones para restablecer tu contraseña.
            Por favor revisa tu bandeja de entrada y sigue el enlace que te enviamos.
        </p>
        <div class="confirm-actions">
            <a href="/login" class="page-btn-green" aria-label="Volver al inicio de sesión" title="Volver al inicio de sesión"
                data-tooltip="Volver al inicio de sesión" itemprop="url">
                Volver al inicio de sesión
            </a>
        </div>
    </div>
</section>