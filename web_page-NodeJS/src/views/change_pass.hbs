<link rel="stylesheet" href="/css/auth/change-password.css">

{{> main/header}}
<section class="reset-password" role="region" aria-label="Formulario de restablecimiento de contraseña" itemscope
    itemtype="https://schema.org/WebApplication">
    <div class="container max-width">
        <h1 class="section__title" itemprop="name" title="Restablecer Contraseña">Restablecer Contraseña</h1>

        <form action="/api/v1/auth/reset-password" method="POST" class="reset-form" role="form"
            aria-label="Formulario para restablecer contraseña" itemprop="potentialAction" itemscope
            itemtype="https://schema.org/ResetPassword">

            <div class="input-group">
                <label for="email" itemprop="target" title="Correo electrónico registrado">Correo electrónico</label>
                <input type="email" id="email" name="email" placeholder="Ingrese su Email" required
                    aria-required="true">
            </div>

            <div class="input-group">
                <label for="token" title="Código de confirmación enviado por correo">Código de confirmación</label>
                <input type="text" id="token" name="token" placeholder="Ingrese el código de confirmación" required
                    aria-required="true">
            </div>

            <div class="input-group">
                <label for="password" title="Nueva contraseña segura">Nueva contraseña</label>
                <input type="password" id="password" name="password" placeholder="Ingrese la nueva contraseña" required
                    aria-required="true">
            </div>

            <button type="submit" class="page-btn-green" aria-label="Guardar nueva contraseña"
                title="Guardar nueva contraseña" data-tooltip="Guardar nueva contraseña">
                Guardar nueva contraseña
            </button>
        </form>

        {{#if error}}
        <p class="error-message" role="alert" title="Mensaje de error">{{ error }}</p>
        {{/if}}
    </div>
</section>