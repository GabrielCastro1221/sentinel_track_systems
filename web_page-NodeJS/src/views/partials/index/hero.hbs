<link rel="stylesheet" href="/css/index/hero.css">

<section class="hero-section" role="region" aria-label="Sección principal de SentinelTrack Systems">
    <div class="container content">
        <h1 class="container" itemprop="headline">{{this.hero_title}}</h1>
        <p itemprop="description">{{this.hero_subtitle}}</p>
        <div class="container hero-buttons" role="group" aria-label="Acciones principales">
            <a href="/rastrear" class="page-btn-green"
                data-tooltip="Accede a la plataforma de rastreo de SentinelTrack Systems"
                aria-label="Rastrear dispositivos en tiempo real">Rastrear</a>
            <a href="#store" class="page-btn-green" data-tooltip="Explora los dispositivos IoT disponibles"
                aria-label="Ver dispositivos disponibles">Dispositivos disponibles</a>
        </div>
    </div>
</section>