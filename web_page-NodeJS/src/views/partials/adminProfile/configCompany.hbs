<link rel="stylesheet" href="/css/profileAdmin/companyConfig.css">

<section class="admin-section max-width">
    <h1>Configuración de Sentinel Track Systems</h1>
    <div class="return">
        <a href="/perfil-admin" class="page-btn-green" style="font-weight: 600;">Panel del administrador</a>
    </div>
    {{#if companiesConfig.length}}
    <table class="admin-table">
        <thead>
            <tr>
                <th>Nombre Empresa</th>
                <th>Teléfono</th>
                <th>Dirección</th>
                <th>Email</th>
                <th>Instagram</th>
                <th>Facebook</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            {{#each companiesConfig}}
            <tr>
                <td data-label="Nombre Empresa">{{this.company_name}}</td>
                <td data-label="Teléfono">{{this.phone}}</td>
                <td data-label="Dirección">{{this.address}}</td>
                <td data-label="Email">{{this.email}}</td>
                <td data-label="Instagram">
                    <a href="{{this.instagram_link}}" target="_blank">{{this.instagram_link}}</a>
                </td>
                <td data-label="Facebook">
                    <a href="{{this.facebook_link}}" target="_blank">{{this.facebook_link}}</a>
                </td>
                <td data-label="Acciones" class="action">
                    <button class="page-btn success" data-id="{{this._id}}" data-action="edit"><i
                            class="fi fi-rr-pencil icon" title="Editar configuracion"></i></button>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
    {{else}}
    <p class="no-data">No hay configuración registrada para Guardian Pet.</p>
    {{/if}}
</section>

<script src="/js/profileAdmin/companyConfig.js"></script>