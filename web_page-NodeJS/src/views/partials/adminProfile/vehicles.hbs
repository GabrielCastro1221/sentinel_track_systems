<link rel="stylesheet" href="/css/profileAdmin/vehicles.css">

<section class="admin-section max-width">
    <h1>Vehículos Registrados</h1>
    <div class="return">
        <a href="/perfil-admin" class="page-btn-green" style="font-weight: 600;">Panel del administrador</a>
    </div>

    {{#if vehicles.length}}
    <table class="admin-table">
        <thead>
            <tr>
                <th>Foto</th>
                <th>Placa</th>
                <th>Tipo</th>
                <th>Marca</th>
                <th>Modelo</th>
                <th>Color</th>
                <th>GPS</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            {{#each vehicles}}
            <tr>
                <td data-label="Foto">
                    {{#if this.photo}}
                    <img src="{{this.photo}}" alt="{{this.licensePlate}}" class="vehicle-avatar" />
                    {{else}}
                    <div class="vehicle-avatar placeholder">{{this.licensePlate.[0]}}</div>
                    {{/if}}
                </td>
                <td data-label="Placa">{{this.licensePlate}}</td>
                <td data-label="Tipo">{{this.type}}</td>
                <td data-label="Marca">{{this.brand}}</td>
                <td data-label="Modelo">{{this.model}}</td>
                <td data-label="Color">{{this.color}}</td>
                <td data-label="gps"><a href="/gps/{{this.gps}}" class="gps-link">{{this.gps}}</a></td>
                <td data-label="Acciones" class="action">
                    <button class="page-btn page-btn-green" data-id="{{this._id}}" data-action="edit">Editar</button>
                    <button class="page-btn-green" data-id="{{this._id}}" data-action="track">Rastrear</button>
                    <button class="page-btn page-btn-red" data-id="{{this._id}}" data-action="delete">Eliminar</button>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
    {{else}}
    <p class="no-data">No hay vehículos registrados en la plataforma en el momento.</p>
    {{/if}}
</section>

<script src="/js/profileAdmin/vehicles.js"></script>