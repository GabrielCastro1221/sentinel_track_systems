<link rel="stylesheet" href="/css/chatBot.css">

<div class="chatbox">
    <div class="chatbox__support">
        <div class="chatbox__header">
            <div class="chatbox__image--header">
                <img src="/assets/images/icon-gps.png" alt="image">
            </div>
            <div class="chatbox__content--header">
                <p class="chatbox__description--header">
                    Me llaman <span class="text-success">Vector.</span><br>
                    Rastreo, protejo y conecto.
                </p>
            </div>
        </div>

        <div class="chatbox__messages"></div>

        <div class="chatbox__footer">
            <input type="text" class="inpt" placeholder="Escribe un mensaje...">
            <button class="chatbox__send--footer empty">Enviar</button>
        </div>
    </div>

    <div class="chatbox__button">
        <button><i class="fi fi-rr-user-robot icon"></i></button>
    </div>
</div>

<script src="/js/main/chatbot.js"></script>