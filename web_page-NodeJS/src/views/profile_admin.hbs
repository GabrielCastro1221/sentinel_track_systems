                data-tooltip="Ver tickets" itemprop="url">
                Ver tickets <i class="fi fi-rr-document" aria-hidden="true"></i>
            </a>
        </div>

        <div class="admin-card" role="listitem" itemscope itemtype="https://schema.org/SoftwareApplication"
            title="Configurar parámetros generales de la compañía">
