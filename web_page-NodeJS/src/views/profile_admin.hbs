            <p itemprop="description">Gestiona las mascotas asociadas a los usuarios.</p>
            <a href="/dashboard?section=mascotas" class="page-btn-green" aria-label="Ver mascotas" title="Ver mascotas"
                data-tooltip="Ver mascotas" itemprop="url">
                Ver mascotas <i class="fi fi-rr-paw" aria-hidden="true"></i>
            </a>
