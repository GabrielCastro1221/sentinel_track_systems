            <p itemprop="description">Ajusta parámetros generales del sistema.</p>
            <a href="/dashboard?section=configCompany" class="page-btn-green" aria-label="Ver configuración de la compañía"
                title="Ver configuración de la compañía" data-tooltip="Ver configuración" itemprop="url">
                Ver configuración <i class="fi fi-rr-settings" aria-hidden="true"></i>
            </a>
        </div>

        <div class="admin-card" role="listitem" itemscope itemtype="https://schema.org/SoftwareApplication"
            title="Administrar textos, banners y contenido visual">
            <h3 itemprop="name">Configuración de Página</h3>
            <p itemprop="description">Administra textos, banners y contenido visual.</p>
            <a href="/dashboard?section=configPage" class="page-btn-green" aria-label="Ver configuración de página"
