            <a href="#" id="logout-admin" class="page-btn-red btn-r" aria-label="Salir del administrador"
                title="Salir del administrador" data-tooltip="Salir del administrador" itemprop="url">
                Salir <i class="fi fi-rr-power" aria-hidden="true"></i>
            </a>
