<link rel="stylesheet" href="/css/profileAdmin/profileAdmin.css">

<section class="admin-profile" role="region" aria-label="Panel de Administración Sentinel Track Systems" itemscope
    itemtype="https://schema.org/WebApplication">
    <h2 itemprop="name" title="Panel de Administración Sentinel Track Systems">
        Panel de Administración <span>Sentinel Track Systems</span>
    </h2>
    <p class="subtitle" itemprop="description" title="Gestiona todos los datos de Sentinel Track Systems">
        Gestiona todos los datos de Sentinel Track Systems desde aquí.
    </p>

    <div class="admin-grid" role="list" aria-label="Lista de módulos de administración">
        <div class="admin-card" role="listitem" itemscope itemtype="https://schema.org/SoftwareApplication"
            title="Administrar usuarios registrados">
            <h3 itemprop="name">Usuarios</h3>
            <p itemprop="description">Administra los perfiles registrados en el sistema.</p>
            <a href="/dashboard?section=usuarios" class="page-btn-green" aria-label="Ver usuarios" title="Ver usuarios"
                data-tooltip="Ver usuarios" itemprop="url">
                Ver usuarios <i class="fi fi-rr-user" aria-hidden="true"></i>
            </a>
        </div>

        <div class="admin-card" role="listitem" itemscope itemtype="https://schema.org/SoftwareApplication"
            title="Administrar productos disponibles">
            <h3 itemprop="name">Productos</h3>
            <p itemprop="description">Administra los productos disponibles en la tienda.</p>
            <a href="/dashboard?section=productos" class="page-btn-green" aria-label="Ver productos" title="Ver productos"
                data-tooltip="Ver productos" itemprop="url">
                Ver productos <i class="fi fi-rr-box" aria-hidden="true"></i>
            </a>
        </div>

        <div class="admin-card" role="listitem" itemscope itemtype="https://schema.org/SoftwareApplication"
            title="Organizar productos por categorías">
            <h3 itemprop="name">Categorías</h3>
            <p itemprop="description">Organiza los productos por categorías.</p>
            <a href="/dashboard?section=categorias" class="page-btn-green" aria-label="Ver categorías" title="Ver categorías"
                data-tooltip="Ver categorías" itemprop="url">
                Ver categorías <i class="fi fi-rr-layers" aria-hidden="true"></i>
            </a>
        </div>

        <div class="admin-card" role="listitem" itemscope itemtype="https://schema.org/SoftwareApplication"
            title="Gestionar dispositivos GPS Sentinel Track Systems">
            <h3 itemprop="name">Dispositivos GPS</h3>
            <p itemprop="description">Gestiona los dispositivos GPS Sentinel Track Systems.</p>
            <a href="/dashboard?section=gps" class="page-btn-green" aria-label="Ver dispositivos GPS"
                title="Ver dispositivos GPS" data-tooltip="Ver dispositivos GPS" itemprop="url">
                Ver dispositivos <i class="fi fi-rr-location-alt" aria-hidden="true"></i>
            </a>
        </div>

        <div class="admin-card" role="listitem" itemscope itemtype="https://schema.org/SoftwareApplication"
            title="Configurar tarifas y ciudades de envío">
            <h3 itemprop="name">Envíos</h3>
            <p itemprop="description">Configura tarifas y ciudades de envío.</p>
            <a href="/dashboard?section=envios" class="page-btn-green" aria-label="Ver envíos" title="Ver envíos"
