{
  "name": "sentineltrack_systems",
  "version": "1.0.0",
  "description": "SentinelTrack Systems es una plataforma integral para la gestión de activos, dispositivos GPS, carritos de compras, configuraciones empresariales y páginas informativas. Incluye autenticación segura, subida de archivos, integración con MongoDB y documentación de APIs con Swagger. Diseñada para empresas que buscan control, trazabilidad y eficiencia en sus operaciones.",
  "main": "app.js",
  "scripts": {
    "dev": "nodemon src/app.js --mode dev",
    "start": "node src/app.js --mode build",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "gestión de activos",
    "sistema de rastreo GPS",
    "carrito de compras",
    "configuración de empresa",
    "páginas de configuración",
    "categorías de productos",
    "personas con discapacidad",
    "seguimiento de ubicación",
    "plataforma IoT",
    "API REST",
    "documentación Swagger",
    "autenticación JWT",
    "subida de archivos",
    "Cloudinary",
    "Multer",
    "MongoDB",
    "Mongoose",
    "socket.io",
    "notificaciones en tiempo real",
    "correo electrónico nodemailer",
    "pruebas automatizadas",
    "Jest",
    "Supertest",
    "SentinelTrack Systems"
  ],
  "author": "Gabriel Castro Ramirez",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^1.41.3",
    "commander": "^14.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-handlebars": "^8.0.4",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "mongoose": "^9.1.5",
    "mongoose-paginate-v2": "^1.9.1",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^7.0.13",
    "pdfkit": "^0.18.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  }
}
